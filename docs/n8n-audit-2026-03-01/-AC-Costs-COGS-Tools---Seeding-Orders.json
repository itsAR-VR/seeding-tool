        "jsonBody": "={\n  \"query\": \"query GetOrders($query: String!) { orders(first: 250, query: $query) { edges { node { id name createdAt tags customer { firstName lastName email } lineItems(first: 100) { edges { node { title quantity product { id title } variant { id title sku inventoryItem { unitCost { amount } } } } } } } } pageInfo { hasNextPage endCursor } } }\",\n  \"variables\": {\n    \"query\": \"created_at:>={{ $now.startOf('day').minus({ days: parseInt($('Configuración3').item.json.days_back) }).toFormat('yyyy-MM-dd') }} tag:{{ $('Configuración3').item.json.tag_filter }}\"\n  }\n}",
