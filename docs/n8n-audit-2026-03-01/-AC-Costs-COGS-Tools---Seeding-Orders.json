{
  "name": "[AC] Costs COGS + Tools - Seeding Orders",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst config = $('Configuración3').first().json;\n\nconst targetVariantId = config.variant_id;\nconst targetTag = config.tag_filter;\n\nif (response.errors) {\n  throw new Error('Error GraphQL: ' + JSON.stringify(response.errors));\n}\n\nconst orders = response.data?.orders?.edges || [];\n\nlet orderList = [];\nlet totals = {\n  orders: 0,\n  quantity: 0,\n  cost_of_goods_sold: 0\n};\n\nfor (const orderEdge of orders) {\n  const order = orderEdge.node;\n  \n  // Verificar tag\n  const orderTags = order.tags || [];\n  const hasTag = orderTags.some(tag => tag.toLowerCase() === targetTag.toLowerCase());\n  if (!hasTag) continue;\n  \n  const lineItems = order.lineItems?.edges || [];\n  \n  for (const lineEdge of lineItems) {\n    const line = lineEdge.node;\n    \n    // Filtrar por variant_id\n    const variantGid = line.variant?.id || '';\n    const variantIdFromGid = variantGid.split('/').pop();\n    \n    if (variantIdFromGid !== targetVariantId) continue;\n    \n    const quantity = line.quantity || 0;\n    const unitCost = parseFloat(line.variant?.inventoryItem?.unitCost?.amount || 0);\n    const lineCOGS = quantity * unitCost;\n    \n    totals.orders += 1;\n    totals.quantity += quantity;\n    totals.cost_of_goods_sold += lineCOGS;\n    \n    // Detalle para validar\n    orderList.push({\n      order_number: order.name,\n      order_date: order.createdAt.split('T')[0],\n      customer: order.customer ? `${order.customer.firstName || ''} ${order.customer.lastName || ''}`.trim() : 'Sin cliente',\n      customer_email: order.customer?.email || 'N/A',\n      product: line.product?.title || line.title,\n      variant: line.variant?.title || 'Default',\n      sku: line.variant?.sku || 'N/A',\n      quantity: quantity,\n      unit_cost: unitCost.toFixed(2),\n      line_cogs: lineCOGS.toFixed(2),\n      order_link: `https://admin.shopify.com/store/${config.shopify_store}/orders/${order.id.split('/').pop()}`\n    });\n  }\n}\n\n// Ordenar por fecha\norderList.sort((a, b) => a.order_date.localeCompare(b.order_date));\n\nreturn [\n  {\n    json: {\n      resumen: {\n        total_pedidos_con_producto: totals.orders,\n        total_unidades: totals.quantity,\n        costo_por_unidad: totals.quantity > 0 ? (totals.cost_of_goods_sold / totals.quantity).toFixed(2) : '0.00',\n        total_cogs: totals.cost_of_goods_sold.toFixed(2)\n      },\n      instrucciones_validacion: {\n        paso_1: 'Ve a https://admin.shopify.com/store/kalmwellness/orders?tag=seeding',\n        paso_2: 'Filtra por los últimos 90 días',\n        paso_3: 'Cuenta cuántos pedidos tienen la variante 49935214379325 (30 Strips - Pink)',\n        paso_4: 'Compara con el total_pedidos_con_producto de arriba'\n      },\n      lista_pedidos: orderList\n    }\n  }\n];"
      },
